# Base URL used by server-side fetches. In development, leave blank (auto-detects http://localhost:3000).
# In production, set this to your deployed domain, e.g. https://emazingira.go.tz
NEXT_PUBLIC_SITE_URL=

# Database — when you move beyond the in-memory seed in src/lib/db/data.js,
# set these and wire them up inside that file. (Supabase example shown.)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
